{
  "compilerOptions": {
    "strict": true,
    // tell typescript to generate ESM syntax
    "target": "esnext",
    // tell typescript to require ESM syntax as input (including .js file import)
    "module": "nodenext",
    // define where to put generated js
    "rootDir": ".",
    "outDir": "../../dist-electron",
    // ignore errors from dependencies
    "skipLibCheck": true
  }
}
