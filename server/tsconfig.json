{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,

    // Recommended Options
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "moduleDetection": "force",
    "skipLibCheck": true
  },

  "include": ["src"]
}
